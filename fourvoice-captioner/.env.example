# ==============================================
# FourVoice Captioner — Environment Variables
# ==============================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env with real keys to version control.
# ==============================================

# Fireworks AI API credentials — REQUIRED
FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Model overrides (optional — defaults are set in fourvoice_captioner.py)
# VISION_MODEL=accounts/fireworks/models/kimi-k2p6
# GROUNDING_TEXT_MODEL=accounts/fireworks/models/deepseek-v4-pro
# STYLE_TEXT_MODEL=accounts/fireworks/models/deepseek-v4-pro
# JUDGE_TEXT_MODEL=accounts/fireworks/models/deepseek-v4-pro
# WHISPER_MODEL=whisper-v3
